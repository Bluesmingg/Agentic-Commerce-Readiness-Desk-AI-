      "step": 3,
      "task": "Compare DOM content with Product/Offer/Breadcrumb/FAQPage structured data. Flag missing or contradictory fields.",
      "pages": ["/products/trail-shell-jacket", "/collections/bags", "/pages/shipping-policy"],
      "validate": ["Product.name matches og:title", "Offer.price matches visible price", "ItemList exists on collection", "FAQPage exists on policy"]
    },
    {
