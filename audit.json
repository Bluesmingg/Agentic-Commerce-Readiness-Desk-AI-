      "id": "ACR-001",
      "severity": "critical",
      "category": "checkout",
      "page": "/products/trail-shell-jacket",
      "signal": "Variant selection changes price visually, but JSON-LD Offer keeps a stale single price.",
      "title": "Variant price and structured data disagree",
      "businessImpact": "Shopping agents may quote the wrong price or fail trust checks before sending buyers to checkout.",
      "fix": "Render per-variant Offer data or update JSON-LD on variant change; include priceCurrency, availability and sku.",
      "effort": "M",
      "evidence": {
        "screenshots": [
          "evidence/screenshots/trail-shell-jacket_desktop.png",
          "evidence/screenshots/trail-shell-jacket_mobile.png"
