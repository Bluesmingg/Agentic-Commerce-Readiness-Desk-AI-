{
  "name": "agentic-commerce-readiness",
  "version": "1.0.0",
  "private": true,
  "description": "Agentic Commerce Readiness Desk — AI shopping readiness audit for Shopify/DTC stores",
  "scripts": {
    "collect": "node collector-playwright.js",
    "validate": "node --check collector-playwright.js && node -e \"JSON.parse(require('fs').readFileSync('audit.json','utf8')); console.log('audit.json ok')\"",
    "serve": "npx serve ."
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
